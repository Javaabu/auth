{
    "name": "javaabu/auth",
    "description": "Laravel Authentication Helpers",
    "homepage": "https://github.com/Javaabu/auth",
    "license": "MIT",
    "authors": [
        {
            "name": "Athfan Khaleel",
            "email": "athfan@javaabu.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.7 || ^12.0 || ^13.0",
        "javaabu/helpers": "^1.71",
        "javaabu/activitylog": "^1.6",
        "laravel/ui": "^4.6",
        "javaabu/passport": "^2.0",
        "spatie/laravel-medialibrary": "^11.21",
        "mobiledetect/mobiledetectlib": "^4.8",
        "javaabu/schema": "^1.2"
    },
    "require-dev": {
        "orchestra/testbench": "^9.16 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.5.3 || ^12.5.8 || ^13.0.3"
    },
    "autoload": {
        "psr-4": {
            "Javaabu\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Javaabu\\Auth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Javaabu\\Auth\\AuthServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
